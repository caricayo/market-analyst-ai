{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "rarity", "tags", "lore", "effects"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "rarity": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } },
      "lore": { "type": "string" },
      "effects": { "type": "array", "items": { "type": "string" } },
      "unique": { "type": "boolean" }
    }
  }
}
