{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "body", "tags", "choices"],
    "properties": {
      "id": { "type": "string" },
      "title": { "type": "string" },
      "cardId": { "type": "string" },
      "body": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
      "tags": { "type": "array", "items": { "type": "string" } },
      "onEnterEffects": { "type": "array" },
      "choices": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "text", "next"],
          "properties": {
            "id": { "type": "string" },
            "text": { "type": "string" },
            "requires": { "type": "array" },
            "cost": { "type": "object" },
            "check": { "type": "object" },
            "effects": { "type": "array" },
            "outcomes": { "type": "object" },
            "next": { "type": "object" }
          }
        }
      }
    }
  }
}
