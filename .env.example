# TriView Capital — Environment Variables
# Copy this file to .env and fill in your API keys.

# Required: OpenAI API key (used for GPT-5 / GPT-5 Mini calls)
OPENAI_API_KEY=sk-your-key-here

# Enable strict fact-first Stage 2 output (PART A narrative + PART B claims ledger JSON)
# FACT_FIRST_DEEP_DIVE_ENABLED=true
# Optional: model for post-deep-dive institutional memo enrichment
# INSTITUTIONAL_LAYER_MODEL=gpt-5-mini

# Optional: override pricing defaults (USD) if your account tier differs.
# OPENAI_GPT41_MINI_INPUT_PER_1M=0.40
# OPENAI_GPT41_MINI_CACHED_INPUT_PER_1M=0.10
# OPENAI_GPT41_MINI_OUTPUT_PER_1M=1.60
# OPENAI_WEB_SEARCH_PREVIEW_NON_REASONING_PER_1K=25
