# ============================================================
#  Crypto Trading System — Environment Variables Template
#  Copy to .env and fill in real values. NEVER commit .env
# ============================================================

# --- Coinbase Advanced API ---
# Generate at https://www.coinbase.com/settings/api
# IMPORTANT: Enable "trade" permission ONLY — never withdrawal
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# --- OpenAI (AI Morning Gatekeeper) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Discord Alerts ---
# Create a webhook at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# --- Email Kill-Switch Fallback ---
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECIPIENT=your_alert_email@example.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# --- CoinGecko (free tier, no key required for basic calls) ---
# Uncomment and add key if you upgrade to a paid plan
# COINGECKO_API_KEY=your_coingecko_key_here

# --- System ---
# Set to "true" for paper trading, "false" for live (requires explicit confirmation)
PAPER_TRADING=true
LOG_LEVEL=INFO

# --- Database (Production: Supabase PostgreSQL) ---
# Leave blank locally (uses SQLite). Set in Railway env vars.
# Get from: Supabase > Settings > Database > URI (Transaction pooler, port 6543)
DATABASE_URL=
